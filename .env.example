# Sigil API Environment Configuration

# === Required Configuration ===

# Database
SIGIL_DATABASE_URL=postgresql://user:password@localhost:5432/sigil

# JWT Authentication  
SIGIL_JWT_SECRET=your-super-secure-jwt-secret-here

# === Email Newsletter (Forge Weekly) ===

# Resend API Key (required for email sending)
SIGIL_RESEND_API_KEY=re_your_resend_api_key_here

# Email sender configuration
SIGIL_FROM_EMAIL=noreply@sigilsec.ai
SIGIL_FROM_NAME="Sigil Security"

# Base URL for email links
SIGIL_BASE_URL=https://api.sigilsec.ai

# === Optional Configuration ===

# Redis (for caching and rate limiting)
SIGIL_REDIS_URL=redis://localhost:6379

# Application Settings
SIGIL_DEBUG=false
SIGIL_LOG_LEVEL=INFO
SIGIL_CORS_ORIGINS=["https://app.sigilsec.ai","https://forge.sigilsec.ai"]
SIGIL_FRONTEND_URL=https://app.sigilsec.ai

# External APIs
SIGIL_OPENAI_API_KEY=sk-your_openai_api_key_here
SIGIL_ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
SIGIL_GITHUB_TOKEN=ghp_your_github_token_here

# Monitoring
SIGIL_METRICS_ENABLED=true
SIGIL_AZURE_INSIGHTS_KEY=your_azure_insights_key_here

# SMTP (legacy email alerts)  
SIGIL_SMTP_HOST=smtp.resend.com
SIGIL_SMTP_PORT=587
SIGIL_SMTP_USER=resend
SIGIL_SMTP_PASSWORD=your_resend_api_key
SIGIL_SMTP_FROM_EMAIL=alerts@sigilsec.ai

# Billing (Stripe)
SIGIL_STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
SIGIL_STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# GitHub App Integration
SIGIL_GITHUB_APP_ID=123456
SIGIL_GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----..."