# Forge API Configuration
NEXT_PUBLIC_FORGE_API_URL=http://localhost:8000
NEXT_PUBLIC_FORGE_WS_URL=ws://localhost:8000

# Server-side Forge backend (used by API proxy routes, not exposed to browser)
# NOTE: Infrastructure routes through /api/forge/*, not /forge/*
FORGE_BACKEND_URL=https://api.sigilsec.ai/api/forge
# Optional API key for authenticated backend access (if infrastructure requires it)
FORGE_API_KEY=

# Analytics (Optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Environment
NODE_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_WEBSOCKETS=true

# Cache Configuration
NEXT_PUBLIC_CACHE_TTL=300000