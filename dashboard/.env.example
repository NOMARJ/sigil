# Sigil Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.

# --- API Backend ---
# URL of the Sigil API service
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Auth0 (REQUIRED for OAuth / GitHub + Google login) ---
# Get these from: https://manage.auth0.com/dashboard
AUTH0_SECRET=<openssl rand -hex 32>
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://auth.sigilsec.ai
AUTH0_CLIENT_ID=<auth0-client-id>
AUTH0_CLIENT_SECRET=<auth0-client-secret>
AUTH0_AUDIENCE=https://api.sigilsec.ai

# --- Telemetry ---
NEXT_TELEMETRY_DISABLED=1
